{
  "name": "Oracle Agent Memory Workshop",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "hostRequirements": {
    "cpus": 4
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false,
      "enableNonRootDocker": "true"
    }
  },

  "forwardPorts": [1521],
  "portsAttributes": {
    "1521": { "label": "Oracle DB", "onAutoForward": "silent" }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "docker compose -f .devcontainer/docker-compose.yml start oracle 2>/dev/null || docker compose -f .devcontainer/docker-compose.yml up -d oracle",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.notebookFileRoot": "${containerWorkspaceFolder}/workshop"
      }
    }
  },

  "remoteEnv": {
    "ORACLE_DSN": "localhost:1521/FREEPDB1",
    "ORACLE_USER": "VECTOR",
    "ORACLE_PASSWORD": "VectorPwd_2025"
  }
}
